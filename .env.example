# ─── Server ───────────────────────────────────────────────────────────────────

# REQUIRED: Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Port the Express server listens on (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins
# Development: http://localhost:5173
# Production:  https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────

# Set to true ONLY in .env.development to enable the demo data layer.
# This flag is stripped out in production builds.
VITE_DEMO_MODE=false

# ─── Email Notifications ───────────────────────────────────────────────────────
# Leave EMAIL_HOST blank to run in dry-run mode (logs emails to console).
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=IMS Notifications <your@gmail.com>

# Base URL used in email links
APP_URL=http://localhost:3001
